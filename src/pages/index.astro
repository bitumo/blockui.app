---
import Base from "../layouts/Base.astro";
import { blocks } from "../blocks";

const categories = Object.entries(blocks);
---

<Base
  title="BlockUI — Copy-paste UI blocks for Astro"
  description="A curated gallery of reusable UI blocks built with Astro and Tailwind CSS. Copy, paste, ship."
>
  <main>
    <section
      class="relative isolate flex h-[calc(100svh-60px)] items-center overflow-hidden px-6 lg:px-8"
    >
      <div aria-hidden="true" class="absolute inset-0 -z-10 overflow-hidden">
        <!-- violet/purple — top left -->
        <div
          class="absolute -top-48 -left-24 h-[500px] w-[640px] rounded-full bg-linear-to-br from-violet-300 via-purple-200 to-transparent opacity-90 blur-3xl dark:from-violet-700 dark:via-purple-800 dark:to-transparent dark:opacity-50"
        >
        </div>
        <!-- sky/cyan — top right -->
        <div
          class="absolute -top-20 -right-20 h-[380px] w-[520px] rounded-full bg-linear-to-bl from-sky-300 via-cyan-200 to-transparent opacity-80 blur-3xl dark:from-sky-700 dark:via-cyan-800 dark:to-transparent dark:opacity-45"
        >
        </div>
        <!-- fuchsia/pink — bottom right -->
        <div
          class="absolute -right-16 -bottom-24 h-[340px] w-[560px] rounded-full bg-linear-to-tl from-fuchsia-300 via-rose-200 to-transparent opacity-75 blur-3xl dark:from-fuchsia-700 dark:via-violet-800 dark:to-transparent dark:opacity-45"
        >
        </div>
      </div>
      <!-- dot grid -->
      <div
        aria-hidden="true"
        class="absolute inset-0 -z-10 bg-[radial-gradient(#cbd5e1_1px,transparent_1px)] bg-size-[20px_20px] opacity-60 dark:bg-[radial-gradient(#1e293b_1px,transparent_1px)] dark:opacity-80"
      >
      </div>
      <!-- central vignette — brightens text area, fades grid/blobs at edges -->
      <div
        aria-hidden="true"
        class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_60%_55%_at_50%_45%,white_10%,transparent_70%)] dark:bg-[radial-gradient(ellipse_60%_55%_at_50%_45%,rgb(3_7_18)_10%,transparent_70%)]"
      ></div>
      <!-- top fade — blends into nav -->
      <div
        aria-hidden="true"
        class="absolute inset-x-0 top-0 -z-10 h-32 bg-linear-to-b from-white to-transparent dark:from-gray-950"
      ></div>
      <!-- bottom fade — blends into next section -->
      <div
        aria-hidden="true"
        class="absolute inset-x-0 bottom-0 -z-10 h-40 bg-linear-to-t from-white to-transparent dark:from-gray-950"
      ></div>

      <div class="mx-auto max-w-3xl text-center">
        <div class="fade-up mb-4 flex justify-center" style="--delay:0ms">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-violet-200 bg-white/80 px-4 py-1.5 text-xs font-semibold text-violet-700 shadow-sm backdrop-blur-sm dark:border-violet-800 dark:bg-gray-900/80 dark:text-violet-400"
          >
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-violet-500"></span>
            Open-source · Built with Astro
          </span>
        </div>
        <h1
          class="fade-up text-4xl font-extrabold tracking-tight text-gray-950 sm:text-5xl lg:text-6xl dark:text-white"
          style="--delay:120ms"
        >
          Beautiful blocks,<br />
          <span
            class="bg-linear-to-r from-violet-600 via-fuchsia-500 to-pink-500 bg-clip-text text-transparent dark:from-violet-400 dark:via-fuchsia-400 dark:to-pink-400"
          >
            ready to ship.
          </span>
        </h1>
        <p
          class="fade-up mx-auto mt-6 max-w-xl text-base leading-7 text-gray-500 dark:text-gray-400"
          style="--delay:240ms"
        >
          A curated gallery of copy-paste UI blocks built with Astro and Tailwind CSS. Each block
          has a live preview, source viewer, and isolated preview page.
        </p>
        <div
          class="fade-up mt-10 flex flex-wrap items-center justify-center gap-3"
          style="--delay:360ms"
        >
          <a
            href="/blocks"
            class="rounded-full bg-gray-950 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-gray-800 dark:bg-white dark:text-gray-950 dark:hover:bg-gray-100"
          >
            Browse blocks
          </a>
          <a
            href="https://github.com"
            class="flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-gray-200 transition hover:ring-gray-400 dark:bg-gray-900 dark:text-gray-300 dark:ring-gray-700 dark:hover:ring-gray-500"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-4 w-4 text-gray-500 dark:text-gray-400"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.185 6.839 9.506.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.461-1.11-1.461-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.337 4.687-4.565 4.934.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.203 22 16.447 22 12.021 22 6.484 17.523 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
            View on GitHub
          </a>
        </div>
        <p class="fade-up mt-6 text-xs text-gray-400 dark:text-gray-500" style="--delay:460ms">
          <span class="font-semibold text-gray-600 dark:text-gray-300">2,400+</span> developers using
          BlockUI
        </p>
      </div>
    </section>

    <style>
      @keyframes fade-up {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .fade-up {
        animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        animation-delay: var(--delay, 0ms);
      }
    </style>

    <section class="border-t border-gray-100 bg-gray-950 px-6 py-14 lg:px-8 dark:border-gray-800">
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
          {
            [
              { value: "2,400+", label: "Developers using BlockUI" },
              { value: "12+", label: "Block categories" },
              { value: "40+", label: "Variants available" },
              { value: "100%", label: "Free and open-source" },
            ].map(({ value, label }) => (
              <div>
                <p class="text-3xl font-extrabold tracking-tight text-white">{value}</p>
                <p class="mt-1 text-sm text-gray-400">{label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="relative border-t border-gray-100 px-6 py-16 lg:px-8 dark:border-gray-800">
      <div class="mx-auto max-w-5xl">
        <div class="mb-6 max-w-lg">
          <p
            class="mb-2 text-xs font-semibold tracking-widest text-gray-400 uppercase dark:text-gray-500"
          >
            Why BlockUI
          </p>
          <h2 class="text-2xl font-bold tracking-tight text-gray-950 dark:text-white">
            Everything you need to ship faster.
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2">
          {
            [
              {
                number: "01",
                title: "Copy, paste, done.",
                body: "Every block is a single self-contained file. No package to install, no peer dependencies, no version drift. Paste it in and it just works.",
              },
              {
                number: "02",
                title: "Plain Tailwind throughout.",
                body: "No custom CSS, no design tokens, no wrapper components. Every class is readable and editable. Tweak spacing or swap colors in seconds.",
              },
              {
                number: "03",
                title: "Preview at every breakpoint.",
                body: "Drag the resize handle or snap to Mobile, Tablet, or Desktop. See exactly how a block behaves before you commit.",
              },
              {
                number: "04",
                title: "Formatted code, ready to copy.",
                body: "Source is Prettier-formatted and syntax-highlighted. One click copies it. Use it in any framework — not just Astro.",
              },
            ].map(({ number, title, body }, i) => (
              <div
                class={[
                  "py-8",
                  i % 2 === 0
                    ? "sm:pr-10"
                    : "sm:border-l sm:border-gray-100 sm:pl-10 dark:sm:border-gray-800",
                  i >= 2 ? "border-t border-gray-100 dark:border-gray-800" : "",
                ].join(" ")}
              >
                <p class="mb-4 font-mono text-xs text-gray-300 dark:text-gray-600">{number}</p>
                <h3 class="mb-2 text-base font-semibold tracking-tight text-gray-950 dark:text-white">
                  {title}
                </h3>
                <p class="text-sm leading-6 text-gray-500 dark:text-gray-400">{body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="blocks"
      class="border-t border-gray-100 bg-gray-50 px-6 py-14 lg:px-8 dark:border-gray-800 dark:bg-gray-900"
    >
      <div class="mx-auto max-w-5xl">
        <div class="mb-8 flex items-baseline justify-between">
          <h2 class="text-2xl font-bold tracking-tight text-gray-950 dark:text-white">
            Browse blocks
          </h2>
          <span class="text-xs text-gray-400">{categories.length} categories</span>
        </div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {
            categories.map(([name, block]) => (
              <a
                href={`/${name}`}
                class="group flex items-center justify-between rounded-xl border border-gray-200 bg-white px-5 py-4 transition hover:border-violet-200 hover:shadow-sm dark:border-gray-800 dark:bg-gray-800 dark:hover:border-violet-800"
              >
                <div>
                  <span class="text-sm font-semibold text-gray-950 capitalize dark:text-white">
                    {name}
                  </span>
                  <p class="mt-0.5 text-xs text-gray-400">
                    {block.variants.length} variant{block.variants.length !== 1 ? "s" : ""}
                  </p>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="h-3.5 w-3.5 shrink-0 text-gray-300 transition group-hover:translate-x-0.5 group-hover:text-violet-500"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="testimonials"
      class="border-t border-gray-100 px-6 py-14 lg:px-8 dark:border-gray-800"
    >
      <div class="mx-auto max-w-5xl">
        <div class="mb-8">
          <h2 class="text-2xl font-bold tracking-tight text-gray-950 dark:text-white">
            Loved by developers
          </h2>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            [
              {
                quote:
                  "BlockUI saved me hours on my last project. I grabbed a hero and a features section, tweaked the colors, and shipped the landing page the same afternoon.",
                name: "Sarah Chen",
                role: "Frontend Engineer",
                avatar: "SC",
                color: "bg-violet-500",
              },
              {
                quote:
                  "Finally a component library that doesn't fight my design system. Because there is no design system — it's just Tailwind. Exactly what I wanted.",
                name: "Marcus Rivera",
                role: "Indie Hacker",
                avatar: "MR",
                color: "bg-sky-500",
              },
              {
                quote:
                  "The code tab showing rendered HTML is genius. I can use these blocks in any project, not just Astro ones. Huge time saver.",
                name: "Priya Nair",
                role: "Full-stack Developer",
                avatar: "PN",
                color: "bg-emerald-500",
              },
              {
                quote:
                  "I've been building Astro sites for two years and BlockUI is now a permanent part of my workflow. The preview resize handle alone is worth it.",
                name: "Tom Berg",
                role: "Web Designer",
                avatar: "TB",
                color: "bg-amber-500",
              },
              {
                quote:
                  "The minimalist variants are stunning. Clean, fast, accessible out of the box. My clients keep asking how I build so quickly — this is my secret.",
                name: "Yuki Sato",
                role: "UI Designer",
                avatar: "YS",
                color: "bg-rose-500",
              },
              {
                quote:
                  "Open source, zero lock-in, and genuinely beautiful blocks. I've tried every similar tool and nothing comes close to how practical BlockUI is.",
                name: "Daniel Webb",
                role: "Software Engineer",
                avatar: "DW",
                color: "bg-fuchsia-500",
              },
            ].map(({ quote, name, role, avatar, color }) => (
              <figure class="rounded-xl border border-gray-200 bg-white p-5 shadow-xs dark:border-gray-800 dark:bg-gray-900">
                <div class="mb-3 flex gap-0.5 text-amber-400" aria-label="5 out of 5 stars">
                  {Array(5)
                    .fill(null)
                    .map(() => (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 16 16"
                        fill="currentColor"
                        class="h-3.5 w-3.5"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M8 1.25a.75.75 0 0 1 .692.463l1.32 3.052 3.316.379a.75.75 0 0 1 .434 1.272l-2.44 2.26.666 3.268a.75.75 0 0 1-1.107.802L8 10.884l-2.881 1.862a.75.75 0 0 1-1.107-.802l.666-3.268-2.44-2.26a.75.75 0 0 1 .434-1.272l3.316-.38L7.308 1.713A.75.75 0 0 1 8 1.25Z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    ))}
                </div>
                <blockquote class="mb-4 text-sm leading-6 text-gray-600 dark:text-gray-300">
                  "{quote}"
                </blockquote>
                <figcaption class="flex items-center gap-2.5">
                  <div
                    class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[10px] font-bold text-white ${color}`}
                  >
                    {avatar}
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-gray-950 dark:text-white">{name}</p>
                    <p class="text-xs text-gray-400">{role}</p>
                  </div>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Base>
