---
const logos = [
  { name: "Vercel"      },
  { name: "Netlify"     },
  { name: "Supabase"    },
  { name: "Cloudflare"  },
  { name: "PlanetScale" },
  { name: "Prisma"      },
];
---

<section class="bg-gray-950 px-6 py-16 lg:px-8">
  <div class="mx-auto max-w-5xl">

    <p class="mb-10 text-center text-xs font-semibold uppercase tracking-widest text-gray-500">
      Trusted by teams at
    </p>

    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-8">
      {logos.map(({ name }) => (
        <div aria-label={name}>
          <!-- Placeholder wordmark — replace with real <img> or <svg> -->
          <span class="text-sm font-semibold tracking-tight text-gray-600 transition hover:text-gray-400">{name}</span>
        </div>
      ))}
    </div>

  </div>
</section>
