---
const steps = [
  {
    title: "Browse the gallery",
    description: "Explore blocks by category. Each ships with multiple variants — bold, minimal, bento.",
  },
  {
    title: "Preview at every breakpoint",
    description: "Drag the resize handle or use presets to check Mobile, Tablet, and Desktop before you commit.",
  },
  {
    title: "Copy the source",
    description: "One click copies Prettier-formatted HTML. Framework-agnostic — works anywhere.",
  },
  {
    title: "Paste and own it",
    description: "Drop it in your project and customise freely. Plain Tailwind classes, no abstractions.",
  },
];
---

<section class="border-t border-gray-100 bg-white px-6 py-24 lg:px-8">
  <div class="mx-auto max-w-3xl">

    <div class="mb-12">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-gray-400">How it works</p>
      <h2 class="text-3xl font-bold tracking-tight text-gray-950">Up and running in minutes.</h2>
    </div>

    <ol class="space-y-0">
      {steps.map(({ title, description }, i) => (
        <li class="grid grid-cols-[2rem_1fr] gap-x-5">
          <!-- Timeline spine -->
          <div class="flex flex-col items-center">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-950 text-xs font-bold text-white">
              {i + 1}
            </div>
            {i < steps.length - 1 && <div class="mt-1 w-px flex-1 bg-gray-100"></div>}
          </div>
          <!-- Content -->
          <div class={`pb-10 ${i === steps.length - 1 ? "pb-0" : ""}`}>
            <p class="mb-1 text-sm font-semibold text-gray-950">{title}</p>
            <p class="text-sm leading-6 text-gray-500">{description}</p>
          </div>
        </li>
      ))}
    </ol>

  </div>
</section>
