---
const steps = [
  {
    number: "01",
    title: "Browse the gallery",
    description: "Explore blocks by category — Hero, Features, Pricing, CTA, and more. Each category ships with multiple variants so you always find the right aesthetic for your project.",
    visual: ["Hero", "Features", "Pricing", "CTA", "Footer", "FAQ"],
  },
  {
    number: "02",
    title: "Preview at every breakpoint",
    description: "Switch between the live preview and the Code tab. Drag the resize handle or snap to Mobile, Tablet, or Desktop presets to see exactly how a block behaves before you commit to it.",
    visual: ["Mobile", "Tablet", "Desktop"],
  },
  {
    number: "03",
    title: "Copy, paste, and own it",
    description: "One click copies the Prettier-formatted source. Every block is a single self-contained file with no dependencies — paste it into your project and it's yours to customise forever.",
    visual: null,
  },
];
---

<section class="bg-gray-50 px-6 py-24 lg:px-8">
  <div class="mx-auto max-w-5xl">

    <div class="mb-16 max-w-xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-violet-600">How it works</p>
      <h2 class="text-4xl font-extrabold tracking-tight text-gray-950 sm:text-5xl">
        Three steps to ship.
      </h2>
    </div>

    <div class="space-y-6">
      {steps.map(({ number, title, description, visual }, i) => (
        <div class={`grid grid-cols-1 items-center gap-8 overflow-hidden rounded-3xl border border-gray-100 bg-white p-10 sm:grid-cols-2 ${i % 2 !== 0 ? "sm:[&>*:first-child]:order-last" : ""}`}>

          <div>
            <p class="mb-4 font-mono text-4xl font-bold text-gray-100">{number}</p>
            <h3 class="mb-3 text-xl font-bold tracking-tight text-gray-950">{title}</h3>
            <p class="text-sm leading-7 text-gray-500">{description}</p>
          </div>

          <div class="flex items-center justify-center rounded-2xl bg-gray-50 p-8">
            {visual ? (
              <div class="flex flex-wrap justify-center gap-2">
                {visual.map((label, j) => (
                  <span class={`rounded-full px-3 py-1.5 text-xs font-semibold ${j === 0 ? "bg-violet-600 text-white" : "bg-white text-gray-500 ring-1 ring-gray-200"}`}>
                    {label}
                  </span>
                ))}
              </div>
            ) : (
              <div class="w-full overflow-hidden rounded-xl bg-gray-950 font-mono text-xs">
                <div class="flex items-center gap-1.5 border-b border-white/10 px-4 py-2.5">
                  <span class="h-2 w-2 rounded-full bg-red-500/50"></span>
                  <span class="h-2 w-2 rounded-full bg-amber-400/50"></span>
                  <span class="h-2 w-2 rounded-full bg-emerald-400/50"></span>
                </div>
                <div class="px-4 py-3 leading-6">
                  <p class="text-gray-600">{"// No imports. No setup."}</p>
                  <p class="text-sky-400">&lt;<span class="text-sky-400">section</span> <span class="text-amber-300">class</span><span class="text-gray-500">=</span><span class="text-emerald-300">"..."</span>&gt;</p>
                  <p class="pl-4 text-white">Your content.</p>
                  <p class="text-sky-400">&lt;/<span class="text-sky-400">section</span>&gt;</p>
                </div>
              </div>
            )}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
