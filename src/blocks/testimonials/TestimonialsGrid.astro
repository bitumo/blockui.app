---
const testimonials = [
  {
    quote: "BlockUI saved me hours on my last project. I grabbed a hero and a features section, tweaked the colors, and shipped the landing page the same afternoon.",
    name: "Sarah Chen",
    role: "Frontend Engineer",
    avatar: "SC",
    color: "bg-violet-500",
  },
  {
    quote: "Finally a component library that doesn't fight my design system. Because there is no design system — it's just Tailwind. Exactly what I wanted.",
    name: "Marcus Rivera",
    role: "Indie Hacker",
    avatar: "MR",
    color: "bg-sky-500",
  },
  {
    quote: "The code tab showing rendered HTML is genius. I can use these blocks in any project, not just Astro ones. Huge time saver.",
    name: "Alex Nair",
    role: "Full-stack Developer",
    avatar: "AN",
    color: "bg-emerald-500",
  },
  {
    quote: "I've been building Astro sites for two years and BlockUI is now a permanent part of my workflow. The preview resize handle alone is worth it.",
    name: "Tom Berg",
    role: "Web Designer",
    avatar: "TB",
    color: "bg-amber-500",
  },
  {
    quote: "The minimalist variants are stunning. Clean, fast, accessible out of the box. My clients keep asking how I build so quickly — this is my secret.",
    name: "Mia Laurent",
    role: "UI Designer",
    avatar: "ML",
    color: "bg-rose-500",
  },
  {
    quote: "Open source, zero lock-in, and genuinely beautiful blocks. I've tried every similar tool and nothing comes close to how practical BlockUI is.",
    name: "Daniel Webb",
    role: "Software Engineer",
    avatar: "DW",
    color: "bg-fuchsia-500",
  },
];
---

<section class="bg-gray-50 px-6 py-24 lg:px-8">
  <div class="mx-auto max-w-5xl">

    <div class="mb-14 text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-violet-600">Testimonials</p>
      <h2 class="text-4xl font-extrabold tracking-tight text-gray-950 sm:text-5xl">
        Loved by developers.
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map(({ quote, name, role, avatar, color }) => (
        <figure class="rounded-2xl border border-gray-200 bg-white p-7 shadow-xs">
          <div class="mb-4 flex gap-0.5 text-amber-400" aria-label="5 out of 5 stars">
            {Array(5).fill(null).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                <path fill-rule="evenodd" d="M8 1.25a.75.75 0 0 1 .692.463l1.32 3.052 3.316.379a.75.75 0 0 1 .434 1.272l-2.44 2.26.666 3.268a.75.75 0 0 1-1.107.802L8 10.884l-2.881 1.862a.75.75 0 0 1-1.107-.802l.666-3.268-2.44-2.26a.75.75 0 0 1 .434-1.272l3.316-.38L7.308 1.713A.75.75 0 0 1 8 1.25Z" clip-rule="evenodd" />
              </svg>
            ))}
          </div>
          <blockquote class="mb-6 text-sm leading-7 text-gray-600">"{quote}"</blockquote>
          <figcaption class="flex items-center gap-3">
            <div class={`flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white ${color}`}>
              {avatar}
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-950">{name}</p>
              <p class="text-xs text-gray-400">{role}</p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
