---
const integrations = [
  { name: "Vercel",      category: "Hosting",        description: "Zero-config deployments from git." },
  { name: "Supabase",    category: "Database",        description: "Postgres, auth, and storage." },
  { name: "Stripe",      category: "Payments",        description: "Accept payments with one API." },
  { name: "Cloudflare",  category: "Infrastructure",  description: "Global edge network and CDN." },
  { name: "Resend",      category: "Email",           description: "Developer-first transactional email." },
  { name: "Prisma",      category: "ORM",             description: "Type-safe database access for Node." },
  { name: "Sentry",      category: "Monitoring",      description: "Error tracking and performance." },
  { name: "Algolia",     category: "Search",          description: "Fast, relevant search at any scale." },
];
---

<section class="border-t border-gray-100 bg-white px-6 py-24 lg:px-8">
  <div class="mx-auto max-w-3xl">

    <div class="mb-12">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-gray-400">Integrations</p>
      <h2 class="text-3xl font-bold tracking-tight text-gray-950">Works with your stack.</h2>
    </div>

    <div class="divide-y divide-gray-100">
      {integrations.map(({ name, category, description }) => (
        <div class="flex items-center justify-between gap-6 py-4">
          <div class="flex items-center gap-4">
            <p class="text-sm font-semibold text-gray-950">{name}</p>
            <p class="hidden text-sm text-gray-400 sm:block">{description}</p>
          </div>
          <span class="shrink-0 rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500">
            {category}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>
