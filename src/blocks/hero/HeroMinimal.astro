---

<section class="bg-white px-6 py-32 sm:py-44 lg:px-8">
  <div class="mx-auto max-w-3xl">
    <!-- Eyebrow -->
    <p class="mb-6 text-xs font-semibold uppercase tracking-widest text-gray-400">
      UI Component Library
    </p>

    <!-- Headline -->
    <h1 class="text-5xl font-light leading-[1.1] tracking-tight text-gray-950 sm:text-6xl lg:text-7xl">
      Beautiful blocks,<br />
      <em class="font-semibold not-italic">ready to ship.</em>
    </h1>

    <!-- Divider -->
    <div class="my-10 h-px w-16 bg-gray-200"></div>

    <!-- Body -->
    <p class="max-w-lg text-base leading-7 text-gray-500">
      A focused collection of copy-paste UI blocks built with Astro and Tailwind CSS.
      No dependencies, no lock-in — just clean markup you own.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-wrap items-center gap-8">
      <a
        href="#"
        class="group inline-flex items-center gap-2 text-sm font-semibold text-gray-950 underline-offset-4 hover:underline"
      >
        Browse blocks
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
            clip-rule="evenodd"
          />
        </svg>
      </a>
      <a href="#" class="text-sm text-gray-400 underline-offset-4 hover:text-gray-600 hover:underline transition-colors">
        View on GitHub
      </a>
    </div>
  </div>
</section>
