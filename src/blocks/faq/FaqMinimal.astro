---
const faqs = [
  {
    question: "Do I need to install anything?",
    answer: "No. Every block is a standalone .astro file. Copy it into your project and it works immediately — no npm install, no config, no peer dependencies.",
  },
  {
    question: "Can I use blocks outside of Astro?",
    answer: "Each block renders to plain HTML with Tailwind classes. Copy the rendered output and paste it into any framework or plain HTML project.",
  },
  {
    question: "Is BlockUI free?",
    answer: "Completely free and open-source under the MIT license. Use it in personal and commercial projects without restriction.",
  },
  {
    question: "How do I customise a block?",
    answer: "Every block uses plain Tailwind classes directly in the markup. Change colors, adjust spacing, restructure the HTML — it's yours to own.",
  },
  {
    question: "Are the blocks accessible?",
    answer: "Yes. Semantic HTML, ARIA attributes, and keyboard navigation are included in every block from the start.",
  },
];
---

<section class="border-t border-gray-100 bg-white px-6 py-24 lg:px-8">
  <div class="mx-auto max-w-2xl">

    <div class="mb-12">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-gray-400">FAQ</p>
      <h2 class="text-3xl font-bold tracking-tight text-gray-950">Common questions.</h2>
    </div>

    <dl class="space-y-8">
      {faqs.map(({ question, answer }) => (
        <div>
          <dt class="mb-2 text-sm font-semibold text-gray-950">{question}</dt>
          <dd class="text-sm leading-6 text-gray-500">{answer}</dd>
        </div>
      ))}
    </dl>

  </div>
</section>
