---
interface BlockEntry {
  name: string;
  description: string;
  variants: string[];
}

interface Props {
  blocks: BlockEntry[];
}

const { blocks } = Astro.props;
---

<!-- Trigger -->
<button
  id="search-trigger"
  aria-label="Search blocks"
  class="flex items-center gap-2 rounded-full border border-gray-200 bg-gray-50 px-3 py-1.5 text-xs text-gray-400 transition hover:border-gray-300 hover:text-gray-600"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 16 16"
    fill="currentColor"
    class="h-3.5 w-3.5 shrink-0"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
      clip-rule="evenodd"></path>
  </svg>
  <span>Search blocks</span>
  <kbd
    class="hidden rounded bg-gray-200 px-1.5 py-0.5 font-mono text-[10px] text-gray-400 sm:inline"
    >⌘K</kbd
  >
</button>

<!-- Dialog -->
<div
  id="search-dialog"
  role="dialog"
  aria-modal="true"
  aria-label="Search blocks"
  style="display:none"
  class="fixed inset-0 z-50"
>
  <!-- Backdrop -->
  <div
    id="search-backdrop"
    style="position:absolute;inset:0;background:rgba(3,7,18,0.5);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)"
  ></div>

  <!-- Panel wrapper -->
  <div class="relative z-10 flex h-full items-start justify-center px-4 pt-24">
    <!-- Panel -->
    <div
      class="w-full max-w-lg overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-2xl"
    >
      <!-- Input -->
      <div class="flex items-center gap-3 border-b border-gray-100 px-4 py-3.5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          fill="currentColor"
          class="h-4 w-4 shrink-0 text-gray-400"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
            clip-rule="evenodd"></path>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search blocks…"
          autocomplete="off"
          class="flex-1 bg-transparent text-sm text-gray-950 outline-none placeholder:text-gray-400"
        />
        <button
          id="search-clear"
          class="hidden text-gray-400 transition hover:text-gray-600"
          aria-label="Clear"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              d="M5.28 4.22a.75.75 0 0 0-1.06 1.06L6.94 8l-2.72 2.72a.75.75 0 1 0 1.06 1.06L8 9.06l2.72 2.72a.75.75 0 1 0 1.06-1.06L9.06 8l2.72-2.72a.75.75 0 0 0-1.06-1.06L8 6.94 5.28 4.22Z"
            ></path>
          </svg>
        </button>
      </div>

      <!-- Results -->
      <ul id="search-results" class="max-h-80 overflow-y-auto py-2"></ul>

      <!-- Footer -->
      <div class="flex items-center justify-between border-t border-gray-100 px-4 py-2.5">
        <div class="flex items-center gap-3 text-xs text-gray-400">
          <span class="flex items-center gap-1">
            <kbd class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[10px]">↑</kbd>
            <kbd class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[10px]">↓</kbd>
            to navigate
          </span>
          <span class="flex items-center gap-1">
            <kbd class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[10px]">↵</kbd>
            to select
          </span>
        </div>
        <span class="text-xs text-gray-400">
          <kbd class="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[10px]">Esc</kbd> to close
        </span>
      </div>
    </div>
  </div>

  <script define:vars={{ blocks }} is:inline>
    const dialog = document.getElementById("search-dialog");
    const trigger = document.getElementById("search-trigger");
    const backdrop = document.getElementById("search-backdrop");
    const input = document.getElementById("search-input");
    const clearBtn = document.getElementById("search-clear");
    const results = document.getElementById("search-results");

    // Move dialog to <body> so `fixed` positioning is relative to the viewport,
    // not the sticky header (which has backdrop-filter, creating a new containing block).
    document.body.appendChild(dialog);

    function open() {
      dialog.style.display = "block";
      requestAnimationFrame(() => input.focus());
    }

    function close() {
      dialog.style.display = "none";
      input.value = "";
      clearBtn.classList.add("hidden");
      render("");
    }

    function render(query) {
      const q = query.trim().toLowerCase();
      const filtered = q
        ? blocks.filter(
            (b) =>
              b.name.toLowerCase().includes(q) ||
              b.description.toLowerCase().includes(q) ||
              b.variants.some((v) => v.toLowerCase().includes(q)),
          )
        : blocks;

      if (filtered.length === 0) {
        results.innerHTML = `
        <li class="px-4 py-8 text-center text-sm text-gray-400">
          No blocks found for "<span class="font-medium text-gray-600">${query}</span>"
        </li>`;
        return;
      }

      results.innerHTML = filtered
        .map(
          (b) => `
        <li>
          <a href="/${b.name}" class="flex items-center justify-between px-4 py-3 transition hover:bg-gray-50">
            <div>
              <p class="text-sm font-semibold capitalize text-gray-950">${b.name}</p>
              <p class="mt-0.5 text-xs text-gray-400">${b.description}</p>
            </div>
            <span class="ml-4 shrink-0 rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-400">
              ${b.variants.length} variant${b.variants.length !== 1 ? "s" : ""}
            </span>
          </a>
        </li>`,
        )
        .join("");
    }

    let activeIndex = -1;

    function getLinks() {
      return Array.from(results.querySelectorAll("a"));
    }

    function setActive(index) {
      const links = getLinks();
      if (!links.length) return;
      activeIndex = Math.max(-1, Math.min(index, links.length - 1));
      links.forEach((a, i) => {
        if (i === activeIndex) {
          a.classList.add("bg-gray-50");
          a.scrollIntoView({ block: "nearest" });
        } else {
          a.classList.remove("bg-gray-50");
        }
      });
    }

    // Initial render
    render("");

    trigger.addEventListener("click", open);
    backdrop.addEventListener("click", close);

    input.addEventListener("input", () => {
      const q = input.value;
      clearBtn.classList.toggle("hidden", !q);
      activeIndex = -1;
      render(q);
    });

    clearBtn.addEventListener("click", () => {
      input.value = "";
      clearBtn.classList.add("hidden");
      activeIndex = -1;
      render("");
      input.focus();
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        open();
      }
      if (e.key === "Escape") close();

      if (dialog.style.display === "none") return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(activeIndex + 1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(activeIndex - 1);
      } else if (e.key === "Enter" && activeIndex >= 0) {
        e.preventDefault();
        getLinks()[activeIndex]?.click();
      }
    });
  </script>
</div>
