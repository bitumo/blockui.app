---
import "../styles/global.css";
import { blocks } from "../blocks";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const categories = Object.keys(blocks);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <header class="sticky top-0 z-40 border-b border-gray-100 bg-white/80 backdrop-blur-sm">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center">
          <img src="/logo.svg" alt="BlockUI" height="28" class="h-[28px] w-auto" />
        </a>
        <nav class="flex items-center gap-6 text-sm text-gray-500">
          {
            categories.map((name) => (
              <a href={`/${name}`} class="capitalize transition hover:text-gray-900">
                {name}
              </a>
            ))
          }
          <a
            href="https://github.com"
            class="rounded-full bg-gray-950 px-4 py-1.5 text-xs font-semibold text-white transition hover:bg-gray-800"
          >
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="border-t border-gray-100 bg-white">
      <div class="mx-auto max-w-5xl px-6 py-14 lg:px-8">
        <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-xs">
            <p class="text-sm font-bold tracking-tight text-gray-950">BlockUI</p>
            <p class="mt-2 text-sm leading-6 text-gray-500">
              A free, open-source gallery of copy-paste UI blocks built with Astro and Tailwind CSS.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-x-16 gap-y-8 text-sm">
            <div>
              <p class="mb-3 font-semibold text-gray-950">Blocks</p>
              <ul class="space-y-2 text-gray-500">
                {
                  categories.map((name) => (
                    <li>
                      <a href={`/${name}`} class="capitalize transition hover:text-gray-900">
                        {name}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <p class="mb-3 font-semibold text-gray-950">Project</p>
              <ul class="space-y-2 text-gray-500">
                <li>
                  <a href="https://github.com" class="transition hover:text-gray-900">GitHub</a>
                </li>
                <li>
                  <a href="https://github.com" class="transition hover:text-gray-900">Contribute</a>
                </li>
                <li>
                  <a href="https://github.com" class="transition hover:text-gray-900">Issues</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
        <div
          class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-gray-100 pt-8 sm:flex-row"
        >
          <p class="text-xs text-gray-400">
            © {new Date().getFullYear()} BlockUI. Open-source under the MIT license.
          </p>
          <p class="text-xs text-gray-400">Built with Astro &amp; Tailwind CSS</p>
        </div>
      </div>
    </footer>
  </body>
</html>
