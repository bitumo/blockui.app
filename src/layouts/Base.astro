---
import "../styles/global.css";
import { blocks } from "../blocks";
import SearchDialog from "../components/SearchDialog.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const categories = Object.keys(blocks);
const searchBlocks = Object.entries(blocks).map(([name, block]) => ({
  name,
  description: block.description,
  variants: block.variants.map((v) => v.slug),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      const dark =
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches);
      document.documentElement.classList.toggle("dark", dark);
    </script>
  </head>
  <body class="bg-white text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
    <header class="sticky top-0 z-40 border-b border-gray-100/60 bg-white/70 backdrop-blur-md dark:border-gray-800/60 dark:bg-gray-950/70">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center">
          <img
            src="/logo.svg"
            alt="BlockUI"
            height="28"
            class="h-7 w-auto dark:brightness-0 dark:invert"
          />
        </a>
        <nav class="flex items-center gap-3">
          <SearchDialog blocks={searchBlocks} />

          <a
            href="https://github.com"
            aria-label="GitHub"
            class="text-gray-400 transition hover:text-gray-950 dark:hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.185 6.839 9.506.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.461-1.11-1.461-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.337 4.687-4.565 4.934.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.203 22 16.447 22 12.021 22 6.484 17.523 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
          <!-- Theme toggle -->
          <button
            id="theme-toggle"
            aria-label="Toggle theme"
            class="text-gray-400 transition hover:text-gray-950 dark:hover:text-white"
          >
            <!-- Moon — shown in light mode -->
            <svg
              id="icon-moon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-4 w-4 dark:hidden"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M9.528 1.718a.75.75 0 0 1 .162.819A8.97 8.97 0 0 0 9 6a9 9 0 0 0 9 9 8.97 8.97 0 0 0 3.463-.69.75.75 0 0 1 .981.98 10.503 10.503 0 0 1-9.694 6.46c-5.799 0-10.5-4.7-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 0 1 .818.162Z"
                clip-rule="evenodd"></path>
            </svg>
            <!-- Sun — shown in dark mode -->
            <svg
              id="icon-sun"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="hidden h-5 w-5 dark:block"
              aria-hidden="true"
            >
              <path
                d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.758 17.303a.75.75 0 0 0-1.061-1.06l-1.591 1.59a.75.75 0 0 0 1.06 1.061l1.591-1.59ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.697 7.757a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 0 0-1.061 1.06l1.59 1.591Z"
              ></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="border-t border-gray-100 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
      <div class="mx-auto max-w-5xl px-6 py-14 lg:px-8">
        <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-xs">
            <p class="text-sm font-bold tracking-tight text-gray-950 dark:text-white">BlockUI</p>
            <p class="mt-2 text-sm leading-6 text-gray-500 dark:text-gray-400">
              A free, open-source gallery of copy-paste UI blocks built with Astro and Tailwind CSS.
            </p>
            <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">
              © {new Date().getFullYear()} BlockUI. Open-source under the MIT license.
            </p>
          </div>
          <div class="flex flex-col gap-6 text-sm">
            <div>
              <p class="mb-3 font-semibold text-gray-950 dark:text-white">Blocks</p>
              <ul class="flex flex-wrap gap-x-6 gap-y-2 text-gray-500 dark:text-gray-400">
                {
                  categories.map((name) => (
                    <li>
                      <a
                        href={`/${name}`}
                        class="capitalize transition hover:text-gray-900 dark:hover:text-white"
                      >
                        {name}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.theme = isDark ? "dark" : "light";
      });
    </script>
  </body>
</html>
